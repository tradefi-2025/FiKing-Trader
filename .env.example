# Repo-root environment variables for local development
# Copy to .env and fill in values.

# PostgreSQL Database
POSTGRES_HOST=your_postgres_host
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_SSLMODE=require

# MongoDB
MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_mongo_password
MONGO_HOST=your_mongo_host
MONGO_URI=mongodb+srv://user:password@host/admin?authSource=admin&tls=true
MONGO_DATABASE=admin

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_QUEUE_NAME=rpc_queue

# Refinitiv API
REFINITIV_API_KEY=your_refinitiv_api_key
REFINITIV_USERNAME=your_refinitiv_username
REFINITIV_PASSWORD=your_refinitiv_password

# Contextualizer API
CONTEXTUALIZER_QUEUE=contextualization_requests
